# ============================================================================
# OpenYabby — Environment configuration
# ============================================================================
# Copy this file to `.env` and fill in the values. Anything left blank uses
# the documented default. Only OPENAI_API_KEY is strictly required to start.
# ============================================================================


# ---------- Required ----------

# OpenAI API key — used by the Realtime API (voice), Whisper (wake word),
# and Mem0 (long-term memory). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...


# ---------- PostgreSQL ----------
# Source of truth for all persistent state (tasks, agents, conversations).
# `./setup.sh` will start a local Postgres via Docker if you don't have one.
# Defaults below match the Docker container (port 5433 to avoid clashing with
# a local Postgres on 5432; user/password "yabby" matching docker-compose.yml).
# If you want to use your own local Postgres, run `./setup.sh local` and edit
# PG_USER / PG_PASSWORD / PG_PORT to match it.

PG_HOST=localhost
PG_PORT=5433
PG_DATABASE=yabby
PG_USER=yabby
PG_PASSWORD=yabby

# Postgres SSL — set to "true" for cloud providers (Neon, Supabase, AWS RDS).
# Leave unset or "false" for local Postgres without SSL.
PG_SSL=


# ---------- Redis ----------
# Live status cache + pub/sub channel. `./setup.sh` will start one if needed.
# In Docker mode, setup.sh defaults the host port to 6380 (to avoid clashing
# with a local Redis on 6379) and rewrites REDIS_URL here accordingly.

REDIS_URL=redis://localhost:6380


# ---------- Claude CLI ----------
# Path to the Claude Code binary used to spawn task runners.
# Default assumes `claude` is on your PATH.

CLAUDE_CMD=claude


# ---------- Server ----------

PORT=3000


# ---------- Optional: Speaker Verification ----------
# Python microservice (FastAPI + SpeechBrain) that filters wake-word audio
# against your enrolled voice profile. Reduces false positives by ~90% in
# multi-person rooms. Yabby works without it (fail-open).
#
# Start with `npm run dev` (boots Node + speaker together) or `npm run speaker`.

SPEAKER_SERVICE_URL=http://localhost:3001
SPEAKER_THRESHOLD=0.25
SPEAKER_DATA_DIR=./data


# ---------- Optional: Auth Gateway ----------
# Off by default (single-user localhost). Turn on if you expose Yabby on a
# network, or set up a reverse proxy with its own auth.

YABBY_AUTH_ENABLED=false
YABBY_AUTH_PASSWORD=


# ---------- Optional: Connector Credential Encryption ----------
# AES-256-GCM key used to encrypt third-party API tokens at rest.
# If unset, derived deterministically from OPENAI_API_KEY — pin an explicit
# value if you ever plan to rotate your OpenAI key.

YABBY_SECRET=


# ---------- Optional: Relay Tunnel ----------
# Yabby connects to relay.openyabby.com so the mobile app can reach your
# local server. Set to `true` to keep everything fully local.

DISABLE_TUNNEL=false


# ---------- Optional: Project Sandbox Location ----------
# Where new project working directories are created.
# Default: ~/Desktop/Yabby Projects

SANDBOX_ROOT=


# ---------- Optional: Docker / Remote Task Mode ----------
# Forward task spawns to a remote host that has the Claude CLI installed.
# Useful when Yabby itself runs in Docker (CLI runners can't run inside
# the Yabby container).

TASKS_FORWARD_URL=
